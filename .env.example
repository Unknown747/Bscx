# ================================================================
# Base Sniper Ultimate v2.0 — Environment Variables
# ================================================================
# Cara pakai di VPS:
#   cp .env.example .env
#   nano .env          # isi nilai yang diperlukan
#   source .env        # atau gunakan PM2 env injection
# ================================================================

# ── SERVER ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── AUTENTIKASI DASHBOARD (WAJIB) ────────────────────────────────
# Password untuk halaman login dashboard web
APP_PASSWORD=ganti_password_kuat_anda_minimal_12_karakter

# ── WALLET (WAJIB untuk live trading) ────────────────────────────
# Private key dompet Anda — JANGAN pernah di-commit ke git!
PRIVATE_KEY=0x_private_key_dompet_anda

# ── AI PROVIDERS (opsional — bot tetap jalan tanpa AI key) ───────
# Minimal 1 key = aktifkan analisis AI real. Tanpa key = rule-based.
# Groq: gratis, tercepat (~88ms) — daftar di console.groq.com
GROQ_API_KEY=
# Gemini: gratis, context 1M — daftar di aistudio.google.com
GEMINI_API_KEY=
# HuggingFace: fallback terakhir — daftar di huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ── TELEGRAM (opsional — notifikasi trade) ───────────────────────
# Buat bot lewat @BotFather, dapatkan Chat ID lewat @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── RPC ENDPOINTS (opsional — default publik sudah cukup) ────────
# Gunakan private RPC (Alchemy/QuickNode/drpc.org) untuk performa lebih baik
BASE_HTTP_URL=https://mainnet.base.org
BASE_WSS_URL=wss://base.drpc.org
BACKUP_HTTP_URL=https://base.publicnode.com
BACKUP_WSS_URL=wss://base-rpc.publicnode.com

# ── BASESCAN API (opsional — untuk deployer reputation check) ────
BASESCAN_API_KEY=

# ── DATABASE (opsional — path DB default sudah benar) ───────────
# Override jika ingin menyimpan DB di lokasi custom di VPS
# DB_PATH=/var/data/base-sniper/base.db

# ── PUSH NOTIFICATIONS (opsional) ────────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
