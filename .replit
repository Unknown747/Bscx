modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["nano"]

[userenv]

[userenv.shared]
BASE_WSS_URL = "wss://mainnet-preconf.base.org"
BASE_HTTP_URL = "https://mainnet-preconf.base.org"
BACKUP_WSS_URL = "wss://base.llamarpc.com"
BACKUP_HTTP_URL = "https://base.llamarpc.com"
TOTAL_CAPITAL_ETH = "0.006"
MAX_TRADE_AMOUNT = "0.002"
MIN_LIQUIDITY_ETH = "0.15"
MAX_LIQUIDITY_ETH = "2.0"
MAX_SLIPPAGE_PERCENT = "8"
TAKE_PROFIT_1_MULTIPLIER = "2.0"
TAKE_PROFIT_1_PERCENTAGE = "50"
TAKE_PROFIT_2_MULTIPLIER = "5.0"
TAKE_PROFIT_2_PERCENTAGE = "50"
STOP_LOSS_PERCENTAGE = "20"
MAX_PRIORITY_FEE_GWEI = "0.005"
MAX_FEE_PER_GAS_GWEI = "0.05"
GAS_MODE = "auto"
COPY_TRADING_ENABLED = "false"
COPY_TRADING_AMOUNT = "0.0003"
COPY_TRADING_DELAY_SECONDS = "2"
COPY_TRADING_MAX_PER_DAY = "10"
COPY_TRADING_TARGETS = "0x742d35Cc6634C0532925a3b844Bc9e7595f0bEbA,0xAb5801a7D398351b8bE11C439e05C5B3259aeC9B,0x15b2Cf6A1F54D4FEd458B0C4412a0d643aE7e625"
MIN_SAFETY_SCORE = "65"
BLOCK_HONEYPOT = "true"
BLOCK_HIGH_TAX = "true"
MAX_TAX_PERCENT = "10"
SCAN_INTERVAL_MS = "200"
ENABLE_FLASHBLOCKS = "true"
MAX_POOL_AGE_SECONDS = "60"
PORT = "8080"
COPY_TRADE_AMOUNT = "0.002"
DCA_ENABLED = "false"
MIN_AI_CONFIDENCE = "75"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/base-sniper && node_modules/.bin/vite --port 5000 --host"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && npm run dev"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080
