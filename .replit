modules = ["nodejs-18", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pkill -f 'node.*dist/index' 2>/dev/null; pkill -f 'node.*supervisor' 2>/dev/null; sleep 1; PORT=5000 node supervisor.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=5000 node artifacts/api-server/supervisor.js"]
build = ["bash", "-c", "cd artifacts/api-server && npm install && npm run build && cd ../base-sniper && npm install && npm run build"]
