modules = ["nodejs-18", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && node supervisor.js"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/base-sniper && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 9999
externalPort = 3000

[deployment]
deploymentTarget = "cloudrun"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
PORT = "8080"
BASE_HTTP_URL = "https://mainnet.base.org"
BASE_WSS_URL = "wss://base.llamarpc.com"
BACKUP_WSS_URL = "wss://base.llamarpc.com"
BACKUP_HTTP_URL = "https://base.llamarpc.com"
TOTAL_CAPITAL_ETH = "0.006"
MAX_TRADE_AMOUNT = "0.0006"
MIN_LIQUIDITY_ETH = "0.15"
MAX_LIQUIDITY_ETH = "2.0"
MAX_SLIPPAGE_PERCENT = "8"
TAKE_PROFIT_1_MULTIPLIER = "2.0"
TAKE_PROFIT_1_PERCENTAGE = "50"
TAKE_PROFIT_2_MULTIPLIER = "5.0"
TAKE_PROFIT_2_PERCENTAGE = "50"
STOP_LOSS_PERCENTAGE = "20"
MAX_PRIORITY_FEE_GWEI = "0.005"
MAX_FEE_PER_GAS_GWEI = "0.05"
GAS_MODE = "auto"
COPY_TRADING_ENABLED = "false"
COPY_TRADING_AMOUNT = "0.0003"
COPY_TRADING_DELAY_SECONDS = "2"
COPY_TRADING_MAX_PER_DAY = "10"
AI_ENABLED = "true"
WHALE_AUTO_SCAN_ENABLED = "false"
WHALE_MIN_SCORE = "60"
GECKO_SCANNER_ENABLED = "false"
DYNAMIC_SIZING_ENABLED = "true"
TRADE_BALANCE_PCT = "10"
MIN_SAFETY_SCORE = "65"
BLOCK_HONEYPOT = "true"
BLOCK_HIGH_TAX = "true"
MAX_TAX_PERCENT = "10"
MAX_OPEN_POSITIONS = "3"
MAX_HOLD_MINUTES = "30"
DCA_ENABLED = "false"
SCAN_INTERVAL_MS = "200"
ENABLE_FLASHBLOCKS = "true"
MAX_POOL_AGE_SECONDS = "60"
VITE_API_URL = ""
